# Server-only. Never expose this value to browser code.
OPENAI_API_KEY=

# The prepared fixture stays deterministic. Set both values below to enable
# schema-constrained GPT-5.6 extraction for user-supplied evidence.
NOTZERO_ENABLE_LIVE_ANALYSIS=false
NOTZERO_MODEL=gpt-5.6
NOTZERO_ANALYSIS_VERSION=phase-5
NOTZERO_SESSION_REQUEST_LIMIT=8
NOTZERO_SESSION_LIVE_LIMIT=3
NOTZERO_GLOBAL_LIVE_LIMIT=25
NOTZERO_CACHE_TTL_SECONDS=1800
