# Server-only. Never expose this value to browser code and never commit a real
# key. Optional: visitors can instead supply their own key in the interface,
# which is used per request and never stored.
OPENAI_API_KEY=

# The prepared fixture stays deterministic. Set OPENAI_API_KEY and
# NOTZERO_ENABLE_LIVE_ANALYSIS=true to run the deployment's own server-side
# GPT-5.6 analysis for user-supplied evidence without a visitor key.
NOTZERO_ENABLE_LIVE_ANALYSIS=false

# Visitor-supplied API keys (the "Add your OpenAI API key" panel). Set to false
# for deployments that must not accept outside keys.
NOTZERO_ALLOW_USER_KEYS=true

# Grounds generated packs (any field the curated software pack does not cover) in
# real current job postings located by GPT-5.6 web search, so a nursing, law, or
# accounting graduate gets counts over real openings instead of imagined role
# archetypes. When the search finds too few postings it falls back to archetypes
# automatically. Set to false for a model tier without the web-search tool.
NOTZERO_ENABLE_JOB_SEARCH=true

# GPT-5.6 Luna is the cost-efficient GPT-5.6 variant. The bare "gpt-5.6" alias
# routes to Sol, so the variant is named explicitly.
NOTZERO_MODEL=gpt-5.6-luna
NOTZERO_REASONING_EFFORT=max

NOTZERO_ANALYSIS_VERSION=phase-7
NOTZERO_SESSION_REQUEST_LIMIT=8
NOTZERO_SESSION_LIVE_LIMIT=3
NOTZERO_GLOBAL_LIVE_LIMIT=25
NOTZERO_CACHE_TTL_SECONDS=1800
